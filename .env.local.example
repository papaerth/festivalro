# ┌─────────────────────────────────────────────────────────────┐
# │  축제로 환경변수 예시 파일                                     │
# │                                                              │
# │  나중에 한국관광공사 TourAPI 키를 발급받으면:                  │
# │  1) 이 파일을 복사해서 이름을 ".env.local" 로 바꾸고           │
# │  2) 아래 줄의 여기에_키를_붙여넣기 자리에 실제 키를 넣으세요.  │
# │                                                              │
# │  키가 없으면 자동으로 내장 샘플 축제 데이터로 동작합니다.       │
# └─────────────────────────────────────────────────────────────┘

TOUR_API_KEY=여기에_키를_붙여넣기

# ── (선택) 킨텍스(KINTEX) 전시·박람회 일정 — 경기데이터드림 ──
# 코엑스·벡스코 등 전국 전시·공연은 위 TOUR_API_KEY로 자동 수집됩니다.
# 킨텍스(고양) 전용 일정까지 붙이려면 data.gg.go.kr(경기데이터드림)에서
# 무료 인증키를 발급받아 아래에 넣으세요. 비워두면 킨텍스만 빠지고 나머지는 정상.
# GG_DATA_KEY=여기에_경기데이터드림_인증키
# (참고) 전시·공연 자동수집을 끄려면: EVENTS_API_ENABLED=false

# ── 네이버 검색 API (블로그 후기 탭) ──
# https://developers.naver.com/apps 에서 무료로 발급 (검색 API 사용 설정)
# 없으면 블로그 탭이 '네이버에서 검색' 링크로 자동 대체됩니다.
NAVER_CLIENT_ID=여기에_Client_ID
NAVER_CLIENT_SECRET=여기에_Client_Secret

# ── Supabase (회원/로그인 + 등록·제보 저장) ──
# https://supabase.com 프로젝트 → Settings → API 에서 복사
# anon key는 공개되어도 되는 키입니다(보안은 DB의 RLS로 보호).
NEXT_PUBLIC_SUPABASE_URL=여기에_Project_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_anon_public_key
# service_role 키 — ⚠️ 서버 전용. 절대 NEXT_PUBLIC_ 붙이지 말 것(브라우저 노출 금지).
# 등록/제보 저장(insert)·게시(승인)·사진 서명URL 발급에만 사용됩니다.
# 없으면 /submit 등록·제보 저장 기능만 비활성화되고 사이트는 정상 동작합니다.
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_key

# ── Resend (제보 폼 → 운영자 이메일 전송) ──
# https://resend.com 가입 후 API Keys에서 발급 (re_ 로 시작)
# 없으면 제보 폼이 '설정 전' 안내로 표시됩니다.
# 무료 플랜은 도메인 인증 전까지 받는 주소가 'Resend 가입 이메일'로 제한됩니다.
RESEND_API_KEY=여기에_Resend_API_Key
REPORT_TO_EMAIL=여기에_받을_이메일주소

# ── Google 번역 API (일부 언어의 소개/프로그램·블로그/영상 제목 자동 번역) ──
# Google Cloud Console에서 'Cloud Translation API' 사용 설정 후 API 키 발급.
# 없으면 해당 텍스트는 한국어 원문으로 표시됩니다(사이트는 정상 동작).
GOOGLE_TRANSLATE_API_KEY=여기에_Google_Translate_API_Key

# ── Claude(AI) 번역 (축제 '소개글' 고품질 번역) ──
# https://console.anthropic.com 에서 API 키 발급(sk-ant-..., 결제 연결 필요).
# 없으면 소개글은 기존 번역(TourAPI 공식/Google)으로 표시됩니다.
ANTHROPIC_API_KEY=여기에_Anthropic_API_Key
TRANSLATE_MODEL=claude-haiku-4-5
